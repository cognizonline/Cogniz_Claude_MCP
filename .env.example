# Cogniz Memory Platform API Configuration

# Your Cogniz API key (get from https://cogniz.online/settings)
COGNIZ_API_KEY=mp_1_your_api_key_here

# API base URL (default: https://cogniz.online)
COGNIZ_BASE_URL=https://cogniz.online

# Default project ID (default: "default")
COGNIZ_PROJECT_ID=default

# Server port for remote MCP (default: 3000)
PORT=3000
